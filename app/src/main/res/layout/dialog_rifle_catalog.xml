<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp">
    <TextView android:text="Barrel/twist from manufacturer specs; zero distance is a starting point — set your actual zero and confirm on paper."
        android:textSize="12sp" android:layout_marginBottom="8dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:text="Brand" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Spinner android:id="@+id/spRifBrand" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:text="Type" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Spinner android:id="@+id/spRifType" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
    <TextView android:id="@+id/tvRifCount" android:textSize="11sp" android:layout_marginTop="6dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <ListView android:id="@+id/lvRifResults"
        android:layout_width="match_parent" android:layout_height="280dp" android:layout_marginTop="4dp"/>
</LinearLayout>
