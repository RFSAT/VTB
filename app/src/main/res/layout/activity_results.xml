<?xml version="1.0" encoding="utf-8"?>
<!-- Fixed (non-scrolling) screen: corrections dominate, compact one-line
     detail rows, chart absorbs ALL remaining space so nothing is wasted. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp">

        <!-- Correction readouts: one full-width line each, auto-sized as
             large as the width allows; the chart absorbs whatever is left -->
        <TextView
            android:id="@+id/tvWindageCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textSize="13sp"
            android:letterSpacing="0.12"
            android:text="WINDAGE" />

        <TextView
            android:id="@+id/tvWindageBig"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textColor="?attr/colorAccent"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="24sp"
            android:autoSizeMaxTextSize="110sp" />

        <TextView
            android:id="@+id/tvElevationCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textSize="13sp"
            android:letterSpacing="0.12"
            android:text="ELEVATION" />

        <TextView
            android:id="@+id/tvElevationBig"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textColor="?attr/colorAccent"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="24sp"
            android:autoSizeMaxTextSize="110sp" />

        <!-- Compact one-line detail rows (auto-shrink to always fit) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target"
                android:textSize="14sp"
                android:fontFamily="monospace" />
            <TextView
                android:id="@+id/tvRowTarget"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="9sp"
                android:autoSizeMaxTextSize="14sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wind"
                android:textSize="14sp"
                android:fontFamily="monospace" />
            <TextView
                android:id="@+id/tvRowWind"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="9sp"
                android:autoSizeMaxTextSize="14sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Impact"
                android:textSize="14sp"
                android:fontFamily="monospace" />
            <TextView
                android:id="@+id/tvRowImpact"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="9sp"
                android:autoSizeMaxTextSize="14sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvWarnings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- v16.0: wind is a property of the AIR, not the rifle — re-apply
             this analysis' measured wind to any saved profile set. -->
        <Button
            android:id="@+id/btnApplyToSet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Apply wind estimate to other profile"
            android:visibility="gone" />

        <!-- v19.0 usability row: hands-free spoken corrections, shot
             history, CSV export for load-development records. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnSpeak" android:text="Speak: off"
                android:textSize="12sp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnHistory" android:text="History"
                android:textSize="12sp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnExportCsv" android:text="CSV"
                android:textSize="12sp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Chart takes every remaining pixel -->
        <com.rfsat.vtb.ui.WindChartView
            android:id="@+id/windChart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>
