<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- v20.0: Display/Units moved here from Home; tab renamed Settings. -->
        <TextView android:id="@+id/tvHeaderDisplay" android:text="Display &amp; units" android:textStyle="bold" android:textSize="18sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>
        <TextView android:text="Display mode" android:textSize="12sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <Spinner android:id="@+id/spinnerTheme"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <TextView android:text="Measurement units" android:textSize="12sp" android:layout_marginTop="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <Spinner android:id="@+id/spinnerUnits"
            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>
        <Switch
            android:id="@+id/swLogTab" android:text="Show Log tab"
            android:layout_marginTop="8dp" android:layout_marginBottom="4dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Switch
            android:id="@+id/swFullScreen" android:text="Full-screen view (hide status and navigation bars)"
            android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <!-- Profile sets (v16.0): named rifle+bullet+scope snapshots. Wind
             measured with one set can be re-applied on the Results screen
             to compute corrections for another. -->
        <TextView android:id="@+id/tvHeaderSets" android:text="Profile sets"
            android:textStyle="bold" android:textSize="18sp"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <Spinner android:id="@+id/spinnerProfileSets"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnSaveSet" android:text="Save as"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnLoadSet" android:text="Load"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnDeleteSet" android:text="Delete"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:id="@+id/tvHeaderRifle" android:text="@string/rifle_profile" android:textStyle="bold" android:textSize="18sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>
        <!-- v20.22: rifle catalogue (third leg beside bullet+scope) so a full
             equipment change never leaves a stale rifle profile behind. -->
        <Button android:id="@+id/btnRifleCatalog" android:text="Choose from catalogue…"
            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
            <Button android:id="@+id/btnRifleCsvExport" android:text="Export CSV" android:textSize="12sp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnRifleCsvImport" android:text="Import CSV" android:textSize="12sp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Name" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etRifleName" android:hint="Rifle name" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Barrel" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etBarrelLength" android:hint="in" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="0.55" android:layout_height="wrap_content" android:textSize="14sp"/>
            <Spinner android:id="@+id/spUBarrel" android:layout_width="0dp" android:layout_weight="0.45" android:minWidth="64dp" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Twist (in/t)" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etTwistRate" android:hint="in/turn" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/tvZeroLabel" android:text="Zero (m)" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etZeroDistance" android:hint="distance" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="0.55" android:layout_height="wrap_content" android:textSize="14sp"/>
            <Spinner android:id="@+id/spUZero" android:layout_width="0dp" android:layout_weight="0.45" android:minWidth="64dp" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:id="@+id/tvHeaderBullet" android:text="@string/bullet_profile" android:textStyle="bold" android:textSize="18sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:layout_marginBottom="8dp"/>
        <!-- v20.6: factory-ammunition catalogue; fills the fields below as a
             seed for the normal edit-and-save flow. -->
        <!-- v20.8: short single-line labels; minWidth/padding zeroed so four
             buttons share the row without wrapping in any theme/font scale. -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
            <Button android:id="@+id/btnAmmoCatalog" android:text="Catalog" android:textSize="12sp"
                android:maxLines="1" android:minWidth="0dp" android:paddingLeft="4dp" android:paddingRight="4dp"
                android:layout_width="0dp" android:layout_weight="1.1" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnChronograph" android:text="Chrono" android:textSize="12sp"
                android:maxLines="1" android:minWidth="0dp" android:paddingLeft="4dp" android:paddingRight="4dp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnBulletCsvExport" android:text="Save" android:textSize="12sp"
                android:maxLines="1" android:minWidth="0dp" android:paddingLeft="4dp" android:paddingRight="4dp"
                android:layout_width="0dp" android:layout_weight="0.9" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnBulletCsvImport" android:text="Load" android:textSize="12sp"
                android:maxLines="1" android:minWidth="0dp" android:paddingLeft="4dp" android:paddingRight="4dp"
                android:layout_width="0dp" android:layout_weight="0.9" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Name" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etBulletName" android:hint="Bullet name" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Diameter" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etCaliber" android:hint="in" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="0.55" android:layout_height="wrap_content" android:textSize="14sp"/>
            <Spinner android:id="@+id/spUCaliber" android:layout_width="0dp" android:layout_weight="0.45" android:minWidth="64dp" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Weight" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etWeightGrains" android:hint="grains" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="0.55" android:layout_height="wrap_content" android:textSize="14sp"/>
            <Spinner android:id="@+id/spUWeight" android:layout_width="0dp" android:layout_weight="0.45" android:minWidth="64dp" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="MV" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etMuzzleVelocity" android:hint="fps" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="0.55" android:layout_height="wrap_content" android:textSize="14sp"/>
            <Spinner android:id="@+id/spUMv" android:layout_width="0dp" android:layout_weight="0.45" android:minWidth="64dp" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- v20.1: MV temperature sensitivity (0 = off) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:text="MV temp coeff (m/s/°C)" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etMvTempCoeff" android:hint="0"
                    android:inputType="numberDecimal|numberSigned" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:text="MV ref temp (°C)" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etMvRefTemp" android:hint="15"
                    android:inputType="numberDecimal|numberSigned" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="BC (G1)" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etBallisticCoefficient" android:hint="G1" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
        </LinearLayout>
        <!-- Tracer rounds: the bright pyrotechnic point is tracked instead of
             the vapor trail, and wind is inferred from the BULLET's lateral
             lag deflection — a different detector AND a different estimator. -->
        <CheckBox android:id="@+id/cbTracer"
            android:text="Tracer round (track bullet, not vapor trail)"
            android:textSize="14sp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <CheckBox android:id="@+id/cbPellet"
            android:text="Airgun pellet/slug (track the projectile in flight)"
            android:textSize="14sp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <!-- Drop calibration (v15.0): the engine's Cd(M) curve is a
             physically-reasonable approximation, not a certified G1 table,
             so official manufacturer drop data is the ground truth. Enter
             one point from the ammo maker's ballistic table (with THAT
             table's stated zero) and the app solves dragCalibrationFactor
             so the simulated drop matches it exactly. -->
        <TextView android:id="@+id/tvHeaderDropCal" android:text="Drop calibration — official ballistic table"
            android:textStyle="bold" android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:id="@+id/tvTableZeroLabel" android:text="Table zero" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etTableZero" android:inputType="numberDecimal"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:id="@+id/tvTableRangeLabel" android:text="Range" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etTableRange" android:inputType="numberDecimal"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:id="@+id/tvTableDropLabel" android:text="Drop" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etTableDrop" android:inputType="numberDecimal"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>
        <Button android:id="@+id/btnCalibrateDrag"
            android:text="Calibrate drag from official drop"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvDragFactor" android:textSize="12sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvDropTable" android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <!-- Wind calibration (v19.0): the vapor estimator assumes the
             drifting trail centroid sits at half the range; crosswind
             scales linearly with that distance. One shot in a wind measured
             by the Kestrel pins the scale factor empirically. -->
        <TextView android:id="@+id/tvHeaderWindCal" android:text="Wind calibration — measured reference"
            android:textStyle="bold" android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:id="@+id/tvTrueWindLabel" android:text="Measured wind" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etTrueWind" android:inputType="numberDecimal"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp"/>
            </LinearLayout>
            <Button android:id="@+id/btnSolveWindScale" android:text="Solve from last shot"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <TextView android:id="@+id/tvWindScale" android:textSize="12sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>



        <TextView android:id="@+id/tvHeaderScope" android:text="@string/scope_profile" android:textStyle="bold" android:textSize="18sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:layout_marginBottom="8dp"/>
        <!-- v20.12: scope catalogue — fills the fields as a seed for the normal
             edit-and-save flow, mirroring the bullet catalogue. -->
        <Button android:id="@+id/btnScopeCatalog" android:text="Choose from catalogue…"
            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
            <Button android:id="@+id/btnScopeCsvExport" android:text="Export CSV" android:textSize="12sp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnScopeCsvImport" android:text="Import CSV" android:textSize="12sp"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
        </LinearLayout>
        <Spinner android:id="@+id/spinnerScopePreset" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Name" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etScopeName" android:hint="Scope name" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Zoom (x)" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etZoomMin" android:hint="min x" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
            <EditText android:id="@+id/etZoomMax" android:hint="max x" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Optics (mm)" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etObjectiveDiameter" android:hint="obj mm" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
            <EditText android:id="@+id/etFocalLength" android:hint="FL mm" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Height (in)" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <EditText android:id="@+id/etHeightAboveBarrel" android:hint="in" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:text="Click" android:textSize="12sp" android:layout_width="84dp" android:layout_height="wrap_content" android:layout_gravity="center_vertical"/>
            <Spinner android:id="@+id/spinnerClickUnit" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button android:id="@+id/btnSave" android:text="@string/save" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp"/>
        <Button android:id="@+id/btnResetDefaults" android:text="@string/reset_defaults" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>

        <TextView android:id="@+id/tvHeaderBackup" android:text="Backup &amp; restore"
            android:textStyle="bold" android:textSize="18sp"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:text="One file holding every profile, profile set, calibration, unit choice and preference. Use this before changing device or reinstalling — the per-section CSV files cover profiles only."
            android:textSize="12sp" android:layout_marginBottom="4dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnBackupExport" android:text="Back up everything…"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnBackupRestore" android:text="Restore from backup…"
            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>
