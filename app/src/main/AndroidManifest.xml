<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <!-- v20.23: scope Wi-Fi stream capture (RTSP to the scope's hotspot) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-feature android:name="android.hardware.camera.any" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- v17.0 Kestrel link: bonded-device BLE connect only (no scanning),
         so no location permission is required. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- v18.0: DROP D3 is BLE-advertising-only (never appears in paired
         devices), so a short scan is required. neverForLocation: we only
         look for the Kestrel, so no location permission on Android 12+;
         pre-12 BLE scanning legally requires fine location. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />

    <application
        android:name="com.rfsat.vtb.VtbApp"
        android:largeHeap="true"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.VTB"
        android:supportsRtl="true">

        <activity
            android:name="com.rfsat.vtb.ui.MainActivity"
            android:label="VTB 1.20.32"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name="com.rfsat.vtb.profiles.ProfileActivity" android:exported="false" />
        <activity android:name="com.rfsat.vtb.capture.CaptureActivity" android:exported="false" />
        <activity android:name="com.rfsat.vtb.results.ResultsActivity" android:exported="false" />
        <activity android:name="com.rfsat.vtb.log.LogActivity" android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
